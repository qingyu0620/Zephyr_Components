// STM32F4 Discovery 设备树 overlay

#include <zephyr/dt-bindings/gpio/gpio.h>
#include <zephyr/dt-bindings/pwm/pwm.h>
#include <zephyr/dt-bindings/dma/stm32_dma.h>

/ {
	chosen {
		zephyr,console = &usart2;
		zephyr,shell-uart = &usart2;
	};
};

/ {
	leds {
		compatible = "gpio-leds";
		led0: led_0 {
			gpios = <&gpiof 9 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
		};
		led1: led_1 {
			gpios = <&gpiof 10 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
		};
	};
};

/ {
	keys {
		compatible = "gpio-keys";
		key0: key_0 {
			gpios = <&gpioe 4 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
		};
	};
};

/* ===== PWM 配置 =====
 * TIM4, CH1=PD12 (50Hz, 舵机)
 */
/ {
	pwm_servo: pwm_servo {
		compatible = "pwm-leds";
		servo: servo {
			pwms = <&pwm4 1 20000000 PWM_POLARITY_NORMAL>;
		};
	};
};

&timers4 {
	status = "okay";
	st,prescaler = <83>;  /* 84MHz / (83+1) = 1MHz, 1us per tick */

	pwm4: pwm {
		status = "okay";
		pinctrl-0 = <&tim4_ch1_pd12>;
		pinctrl-names = "default";
	};
};

/* ===== UART1 配置 =====
 * USART1, TX=PA9, RX=PA10, 115200 baud, DMA 接收
 */
&usart1 {
	pinctrl-0 = <&usart1_tx_pa9 &usart1_rx_pa10>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "okay";

	dmas = <&dma2 7 4 (STM32_DMA_PERIPH_TX | STM32_DMA_PRIORITY_HIGH) STM32_DMA_FIFO_FULL>,
	       <&dma2 2 4 (STM32_DMA_PERIPH_RX | STM32_DMA_PRIORITY_HIGH) STM32_DMA_FIFO_FULL>;
	dma-names = "tx", "rx";
};

&dma2 {
	status = "okay";
};

/* ===== Console =====
 * USART2, TX=PA2, RX=PA3
 */
&usart2 {
	pinctrl-0 = <&usart2_tx_pa2 &usart2_rx_pa3>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "okay";
};
